{{!-- Welcome Page Appearance Editor template --}}
<div class="cl-editor-wrap">

  {{!-- Tab navigation --}}
  <div class="cl-tabs">
    <button type="button" class="cl-tab-btn cl-tab-btn--active" data-action="switchTab" data-tab="appearance">
      <i class="fas fa-palette"></i> Appearance
    </button>
    <button type="button" class="cl-tab-btn" data-action="switchTab" data-tab="page">
      <i class="fas fa-globe"></i> Page Settings
    </button>
  </div>

  {{!-- Aba 1: conteúdo atual --}}
  <div class="cl-tab-panel" data-tab-panel="appearance">

    {{!-- Template selector --}}
    <section class="cl-section">
      <h3 class="cl-section-title">Layout</h3>
      <select class="cl-template-select cl-user-select" name="template">
        <option value="hand-cards" {{#if (eq template "hand-cards")}}selected{{/if}}>Card Hand — 9:16</option>
        <option value="carousel" {{#if (eq template "carousel")}}selected{{/if}}>Carousel — 9:16</option>
        <option value="grid" {{#if (eq template "grid")}}selected{{/if}}>Photo Grid — Square</option>
        <option value="row" {{#if (eq template "row")}}selected{{/if}}>Portrait Row — 9:16</option>
        <option value="sidebar" {{#if (eq template "sidebar")}}selected{{/if}}>Sidebar — Square</option>
        <option value="solar-system" {{#if (eq template "solar-system")}}selected{{/if}}>Solar System — Square</option>
        <option value="sleek-phantom" {{#if (eq template "sleek-phantom")}}selected{{/if}}>Sleek Phantom — 9:16</option>
      </select>
      <p class="cl-hint">Carousel, Portrait Row, Card Hand, and Sleek Phantom layouts use 9:16 images. Photo Grid, Solar System, and Sidebar use square (1:1) images and show no text unless player names are enabled.</p>
    </section>

    {{!-- Background section --}}
    <section class="cl-section">
      <h3 class="cl-section-title">Background</h3>

      <div class="cl-bg-preview-wrap">
        {{#if hasBackground}}
          {{#if isVideo}}
            <video class="cl-bg-preview" src="{{backgroundUrl}}" autoplay muted loop playsinline></video>
          {{else}}
            <img class="cl-bg-preview" src="{{backgroundUrl}}" alt="Background preview" />
          {{/if}}
        {{else}}
          <div class="cl-bg-preview cl-bg-preview--empty">
            <i class="fas fa-image"></i>
            <p>No background set</p>
          </div>
        {{/if}}
      </div>

      <input type="hidden" class="cl-bg-url" name="backgroundUrl" value="{{backgroundUrl}}" />

      <div class="cl-bg-actions">
        <button type="button" class="cl-btn cl-btn--ghost" data-action="pickBackground">
          <i class="fas fa-folder-open"></i> Browse
        </button>
        {{#if worldBg}}
        <button type="button" class="cl-btn cl-btn--ghost" data-action="useWorldBackground">
          <i class="fas fa-globe"></i> Use World Background
        </button>
        {{/if}}
        <button type="button" class="cl-btn cl-btn--ghost" data-action="clearBackground">
          <i class="fas fa-times"></i> Use Template Default
        </button>
      </div>
      <p class="cl-hint">Supports images and videos (mp4, webm, ogv).</p>

      {{!-- Video audio toggle — only shown when a video is selected --}}
      {{#if isVideo}}
      <div class="cl-field cl-field--checkbox" style="margin-top: 0.75rem;">
        <input type="checkbox" id="cl-video-audio" class="cl-video-audio-toggle"
               name="videoAudio" {{#if videoAudio}}checked{{/if}} />
        <label for="cl-video-audio">Enable video audio</label>
      </div>
      <p class="cl-hint">When enabled, the video's audio will play after the user moves the mouse or clicks anywhere on the login screen.</p>
      {{/if}}
    </section>

  </div>

  {{!-- Aba 2: Page Settings --}}
  <div class="cl-tab-panel cl-tab-panel--hidden" data-tab-panel="page">

    {{!-- Favicon section --}}
    <section class="cl-section">
      <h3 class="cl-section-title">Favicon</h3>
      <div class="cl-favicon-preview-wrap">
        {{#if faviconUrl}}
          <img class="cl-favicon-preview" src="{{faviconUrl}}" alt="Favicon preview" />
        {{/if}}
      </div>
      <input type="hidden" class="cl-favicon-url" name="faviconUrl" value="{{faviconUrl}}" />
      <div class="cl-bg-actions">
        <button type="button" class="cl-btn cl-btn--ghost" data-action="pickFavicon">
          <i class="fas fa-folder-open"></i> Browse
        </button>
      </div>
      <p class="cl-hint">Choose the favicon displayed on the browser tab. Supports .ico and image files. Defaults to the module's built-in favicon.</p>
    </section>

    {{!-- Page Title section --}}
    <section class="cl-section">
      <h3 class="cl-section-title">Page Title</h3>
      <input type="text" class="cl-text-input cl-screen-title" name="screenTitle"
             value="{{screenTitle}}" placeholder="Welcome" />
      <p class="cl-hint">Text shown in the browser tab title bar when players open the login screen.</p>
    </section>

  </div>

  {{!-- Actions --}}
  <div class="cl-actions">
    <div>
      <button type="button" class="cl-btn cl-btn--ghost" data-action="previewPage">
        <i class="fas fa-eye"></i> Preview
      </button>
    </div>
    <div class="cl-actions-right">
      <button type="button" class="cl-btn cl-btn--primary" data-action="generatePage">
        <i class="fas fa-save"></i> Save and Close
      </button>
    </div>
  </div>

</div>
